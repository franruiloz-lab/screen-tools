---
import Layout from '../../layouts/Layout.astro';
import ScreenTool from '../../components/ScreenTool.astro';

const hreflang = [
  { lang: 'en', href: '/' },
  { lang: 'es', href: '/es' },
  { lang: 'pt', href: '/pt' },
  { lang: 'tr', href: '/tr' },
  { lang: 'fr', href: '/fr' },
  { lang: 'de', href: '/de' },
];
---

<Layout
  title="Pantalla Blanca | Pantalla Blanca Online Gratis"
  description="Pantalla blanca completa online — perfecta como aro de luz, iluminación para selfies y videollamadas. Ajusta brillo y temperatura de color. Gratis, sin descargas."
  themeColor="#ffffff"
  lang="es"
  canonical="/es"
  hreflang={hreflang}
>
  <ScreenTool
    color="#ffffff"
    showTemp={true}
    pageTitle="Pantalla Blanca Online"
  />
</Layout>

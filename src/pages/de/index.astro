---
import Layout from '../../layouts/Layout.astro';
import ScreenTool from '../../components/ScreenTool.astro';

const hreflang = [
  { lang: 'en', href: '/' },
  { lang: 'es', href: '/es' },
  { lang: 'pt', href: '/pt' },
  { lang: 'tr', href: '/tr' },
  { lang: 'fr', href: '/fr' },
  { lang: 'de', href: '/de' },
];
---

<Layout
  title="Weißer Bildschirm | Weißer Bildschirm Online Kostenlos"
  description="Weißer Vollbildschirm online — perfekt als Ringlicht, Beleuchtung für Selfies und Videoanrufe. Helligkeit und Farbtemperatur einstellbar. Kostenlos, kein Download."
  themeColor="#ffffff"
  lang="de"
  canonical="/de"
  hreflang={hreflang}
>
  <ScreenTool
    color="#ffffff"
    showTemp={true}
    pageTitle="Weißer Bildschirm Online"
  />
</Layout>

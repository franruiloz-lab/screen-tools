---
import Layout from '../../layouts/Layout.astro';
import ScreenTool from '../../components/ScreenTool.astro';

const hreflang = [
  { lang: 'en', href: '/' },
  { lang: 'es', href: '/es' },
  { lang: 'pt', href: '/pt' },
  { lang: 'tr', href: '/tr' },
  { lang: 'fr', href: '/fr' },
  { lang: 'de', href: '/de' },
];
---

<Layout
  title="Beyaz Ekran | Ücretsiz Online Beyaz Ekran"
  description="Tam ekran beyaz ekran online — selfie ve video görüşmeleri için ışık kaynağı olarak kullanın. Parlaklık ve renk sıcaklığı ayarı. Ücretsiz, indirme gerekmez."
  themeColor="#ffffff"
  lang="tr"
  canonical="/tr"
  hreflang={hreflang}
>
  <ScreenTool
    color="#ffffff"
    showTemp={true}
    pageTitle="Beyaz Ekran Online"
  />
</Layout>

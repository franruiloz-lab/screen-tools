---
import Layout from '../layouts/Layout.astro';
import ScreenTool from '../components/ScreenTool.astro';

const hreflang = [
  { lang: 'en', href: '/' },
  { lang: 'es', href: '/es' },
  { lang: 'pt', href: '/pt' },
  { lang: 'tr', href: '/tr' },
  { lang: 'fr', href: '/fr' },
  { lang: 'de', href: '/de' },
];
---

<Layout
  title="White Screen | Free Online White Screen Tool"
  description="Instant fullscreen white screen — use as a ring light, fill light, or for screen cleaning. Adjustable brightness and color temperature. Free, no download needed."
  themeColor="#ffffff"
  lang="en"
  canonical="/"
  hreflang={hreflang}
>
  <ScreenTool
    color="#ffffff"
    showTemp={true}
    pageTitle="White Screen Online"
  />

  <section class="page-content">
    <div class="content-inner">
      <h2>Free Online White Screen Tool</h2>
      <p>YourWhiteScreen gives you an instant fullscreen white display directly in your browser — no app download, no signup, no clutter. Use it as a fill light for photography, a clean background for video calls, or a simple screen-cleaning guide.</p>
      <p>Adjust brightness from 5% to 150% and fine-tune color temperature from cool daylight (6500K) to warm incandescent (3200K). Switch to Ring Light mode for a virtual ring light effect drawn on screen.</p>

      <h3>Common Uses</h3>
      <ul>
        <li><strong>Photography fill light</strong> — hold a second device showing the white screen near your subject for soft, diffused fill lighting</li>
        <li><strong>Video calls</strong> — place a device off-screen to illuminate your face evenly on Zoom or Teams</li>
        <li><strong>Screen cleaning</strong> — a bright white screen shows dust and smudges clearly so you can clean the display properly</li>
        <li><strong>Monitor uniformity test</strong> — check for uneven backlighting or color inconsistencies across your screen</li>
        <li><strong>Light box substitute</strong> — use as a portable light panel for product photography or tracing</li>
      </ul>

      <h3>How to Use</h3>
      <p>Click the fullscreen button (or double-click the screen) to enter fullscreen mode. Use the brightness slider to adjust intensity, and the temperature slider to shift between cool and warm white. Save custom colors using the + button.</p>

      <h3>Frequently Asked Questions</h3>
      <div class="faq">
        <div class="faq-item">
          <h4>Can I use a white screen as a ring light?</h4>
          <p>Yes — a white screen is one of the simplest portable fill lights. Position a tablet or laptop showing the white screen at a 45° angle to your subject. The larger the screen, the softer the light. Adjust brightness to control intensity.</p>
        </div>
        <div class="faq-item">
          <h4>Does a white screen drain battery faster?</h4>
          <p>On OLED and AMOLED displays, yes — white pixels are fully lit and use maximum power. On LCD displays, the backlight is always on so color has minimal effect on battery. If battery matters, use a lower brightness setting.</p>
        </div>
        <div class="faq-item">
          <h4>What color temperature should I use for photography?</h4>
          <p>For neutral daylight fill light, stay near 5500K (center position). For warmer, more flattering skin tones, shift toward 3200K. Match the temperature to your main light source for consistent color balance.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-content {
    background: #f9f9f9;
    padding: 60px 20px;
    border-top: 1px solid #e5e5e5;
  }
  .content-inner {
    max-width: 760px;
    margin: 0 auto;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #333;
    line-height: 1.7;
  }
  .content-inner h2 { font-size: 1.6rem; font-weight: 800; margin-bottom: 16px; color: #111; }
  .content-inner h3 { font-size: 1.1rem; font-weight: 700; margin: 28px 0 10px; color: #222; }
  .content-inner h4 { font-size: 1rem; font-weight: 600; margin-bottom: 6px; color: #333; }
  .content-inner p { margin-bottom: 14px; }
  .content-inner ul { margin: 0 0 14px 20px; }
  .content-inner ul li { margin-bottom: 6px; }
  .faq { display: flex; flex-direction: column; gap: 20px; }
  .faq-item { background: #fff; border: 1px solid #e5e5e5; border-radius: 8px; padding: 18px 20px; }
  .faq-item p { margin: 0; }
</style>

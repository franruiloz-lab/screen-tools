---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Broken Screen | Cracked Screen Prank Online"
  description="Realistic cracked screen prank — looks like your screen is broken with glass cracks. Prank your friends. Free, instant, no download needed."
  themeColor="#0a0a0a"
  lang="en"
  canonical="/broken-screen"
>
  <h1 class="sr-only">Broken Screen Prank Online</h1>
  <div id="broken-app">
    <div id="bg"></div>
    <svg id="cracks" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Impact point ~35% 28% -->
      <!-- Main radial cracks -->
      <path d="M35,28 L2,5"   class="crack main"/>
      <path d="M35,28 L18,0"  class="crack main"/>
      <path d="M35,28 L52,0"  class="crack main"/>
      <path d="M35,28 L72,3"  class="crack main"/>
      <path d="M35,28 L98,12" class="crack main"/>
      <path d="M35,28 L100,35" class="crack main"/>
      <path d="M35,28 L95,58" class="crack main"/>
      <path d="M35,28 L80,80" class="crack main"/>
      <path d="M35,28 L55,100" class="crack main"/>
      <path d="M35,28 L30,100" class="crack main"/>
      <path d="M35,28 L8,95"  class="crack main"/>
      <path d="M35,28 L0,62"  class="crack main"/>
      <path d="M35,28 L0,38"  class="crack main"/>
      <path d="M35,28 L0,20"  class="crack main"/>
      <!-- Secondary cracks branching off -->
      <path d="M20,10 L10,22"  class="crack sec"/>
      <path d="M28,4  L22,15"  class="crack sec"/>
      <path d="M50,8  L44,20"  class="crack sec"/>
      <path d="M65,12 L58,28"  class="crack sec"/>
      <path d="M88,20 L75,32"  class="crack sec"/>
      <path d="M96,42 L82,48"  class="crack sec"/>
      <path d="M90,65 L75,60"  class="crack sec"/>
      <path d="M70,78 L60,65"  class="crack sec"/>
      <path d="M48,92 L42,78"  class="crack sec"/>
      <path d="M30,95 L32,80"  class="crack sec"/>
      <path d="M12,88 L20,75"  class="crack sec"/>
      <path d="M4,72  L14,65"  class="crack sec"/>
      <path d="M3,48  L12,42"  class="crack sec"/>
      <path d="M5,30  L15,36"  class="crack sec"/>
      <!-- Tertiary micro-cracks -->
      <path d="M14,16 L8,28"   class="crack micro"/>
      <path d="M42,6  L38,16"  class="crack micro"/>
      <path d="M78,8  L70,20"  class="crack micro"/>
      <path d="M97,28 L88,35"  class="crack micro"/>
      <path d="M85,72 L73,70"  class="crack micro"/>
      <path d="M58,98 L52,85"  class="crack micro"/>
      <path d="M18,96 L22,82"  class="crack micro"/>
      <path d="M2,55  L10,52"  class="crack micro"/>
    </svg>
    <!-- Impact point glow -->
    <div id="impact"></div>
    <!-- Color glitch strips -->
    <div id="glitch-r"></div>
    <div id="glitch-g"></div>

    <div id="broken-toolbar">
      <button id="btn-tap" class="bbtn">🎯 New crack</button>
      <button id="btn-fs" class="bbtn">⛶ Fullscreen</button>
      <a href={`${base}/`} class="bbtn">← Back</a>
    </div>
  </div>
</Layout>

<style>
  body { background:#000; }
  #broken-app { position:fixed; inset:0; background:#000; overflow:hidden; cursor:none; }
  #bg {
    position:absolute; inset:0;
    background:
      radial-gradient(ellipse 60% 50% at 60% 55%, #1a1a2e 0%, #0a0a0a 60%, #000 100%);
  }
  #cracks {
    position:absolute; inset:0; width:100%; height:100%;
  }
  .crack { fill:none; stroke-linecap:round; }
  .crack.main  { stroke:rgba(255,255,255,0.85); stroke-width:0.5; }
  .crack.sec   { stroke:rgba(255,255,255,0.55); stroke-width:0.3; }
  .crack.micro { stroke:rgba(255,255,255,0.35); stroke-width:0.18; }

  #impact {
    position:absolute;
    width:18px; height:18px;
    border-radius:50%;
    background:radial-gradient(circle, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.3) 40%, transparent 70%);
    left:calc(35% - 9px); top:calc(28% - 9px);
    animation:pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.4)} }

  #glitch-r {
    position:absolute; left:0; right:0; height:3px;
    background:rgba(255,0,50,0.6);
    top:28%; mix-blend-mode:screen;
    animation:glitch-r 4s ease-in-out infinite;
  }
  #glitch-g {
    position:absolute; left:0; right:0; height:2px;
    background:rgba(0,255,100,0.5);
    top:calc(28% + 4px); mix-blend-mode:screen;
    animation:glitch-g 4s ease-in-out infinite 0.3s;
  }
  @keyframes glitch-r {
    0%,90%,100% { opacity:1; transform:translateX(0); }
    92% { transform:translateX(-6px); }
    95% { transform:translateX(4px); }
    97% { transform:translateX(0); opacity:0; }
  }
  @keyframes glitch-g {
    0%,88%,100% { opacity:1; transform:translateX(0); }
    91% { transform:translateX(5px); }
    94% { transform:translateX(-3px); opacity:0.3; }
    96% { opacity:1; }
  }

  #broken-toolbar {
    position:fixed; bottom:0; left:0; right:0;
    display:flex; gap:8px; padding:10px 16px;
    background:rgba(0,0,0,0.85);
    border-top:1px solid #222;
    transition:opacity 0.3s; z-index:100;
  }
  #broken-toolbar.hide { opacity:0; pointer-events:none; }
  .bbtn {
    padding:5px 12px; border-radius:4px;
    border:1px solid #333; background:rgba(30,30,30,0.8);
    color:#ccc; font-size:12px; cursor:pointer; text-decoration:none;
    transition:background 0.15s;
  }
  .bbtn:hover { background:rgba(60,60,60,0.8); }
</style>

<script>
(function () {
  const toolbar = document.getElementById('broken-toolbar');
  const btnFs   = document.getElementById('btn-fs');
  const impact  = document.getElementById('impact');
  const glR     = document.getElementById('glitch-r');
  const glG     = document.getElementById('glitch-g');

  // Random flicker
  setInterval(() => {
    if (Math.random() > 0.92) {
      document.getElementById('broken-app').style.filter = 'brightness(0.1)';
      setTimeout(() => {
        document.getElementById('broken-app').style.filter = '';
      }, 60 + Math.random() * 80);
    }
  }, 800);

  // New crack button — moves impact point
  document.getElementById('btn-tap').addEventListener('click', () => {
    const x = 15 + Math.random() * 70;
    const y = 10 + Math.random() * 70;
    impact.style.left = `calc(${x}% - 9px)`;
    impact.style.top  = `calc(${y}% - 9px)`;
    glR.style.top = `${y}%`;
    glG.style.top = `calc(${y}% + 4px)`;
  });

  // Toolbar auto-hide
  let hideTimer;
  function showBar() {
    toolbar.classList.remove('hide');
    clearTimeout(hideTimer);
    hideTimer = setTimeout(() => toolbar.classList.add('hide'), 3000);
  }
  document.addEventListener('mousemove', showBar, { passive: true });
  document.addEventListener('touchstart', showBar, { passive: true });
  toolbar.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  hideTimer = setTimeout(() => toolbar.classList.add('hide'), 2000);

  btnFs.addEventListener('click', () => {
    if (!document.fullscreenElement) document.documentElement.requestFullscreen();
    else document.exitFullscreen();
  });
})();
</script>
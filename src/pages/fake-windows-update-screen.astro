---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Fake Windows Update Screen | Prank Update Screen Online"
  description="Realistic fake Windows 11 update screen prank. Show a convincing Windows update to fool your friends. Free, instant, no download needed."
  themeColor="#0078d4"
  lang="en"
  canonical="/fake-windows-update-screen"
>
  <h1 class="sr-only">Fake Windows Update Screen Prank Online</h1>
  <div id="win-app">
    <div id="win-bg">
      <!-- Windows 11 update UI -->
      <div id="win-logo">
        <svg viewBox="0 0 88 88" width="72" height="72" xmlns="http://www.w3.org/2000/svg">
          <rect x="2"  y="2"  width="38" height="38" rx="4" fill="white" opacity="0.9"/>
          <rect x="48" y="2"  width="38" height="38" rx="4" fill="white" opacity="0.9"/>
          <rect x="2"  y="48" width="38" height="38" rx="4" fill="white" opacity="0.9"/>
          <rect x="48" y="48" width="38" height="38" rx="4" fill="white" opacity="0.9"/>
        </svg>
      </div>
      <div id="win-spinner">
        <svg viewBox="0 0 50 50" width="48" height="48">
          <circle cx="25" cy="25" r="20" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="4"/>
          <circle id="spin-arc" cx="25" cy="25" r="20" fill="none" stroke="white" stroke-width="4"
            stroke-linecap="round" stroke-dasharray="40 86" stroke-dashoffset="0"/>
        </svg>
      </div>
      <div id="win-pct">0%</div>
      <div id="win-title">Working on updates</div>
      <div id="win-subtitle">Don't turn off your PC. This will take a while.</div>
    </div>
    <div id="win-toolbar">
      <button id="btn-reset" class="wbtn">↺ Restart</button>
      <button id="btn-fs"    class="wbtn">⛶ Fullscreen</button>
      <a href="/"            class="wbtn">← Back</a>
    </div>
  </div>
</Layout>

<style>
  body { background: #0078d4; }
  #win-app { position:fixed; inset:0; background:#0078d4; overflow:hidden; }
  #win-bg {
    position:absolute; inset:0;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:20px;
    background: radial-gradient(ellipse at 50% 30%, #1a8fe0 0%, #0067b8 100%);
    color:white; font-family:'Segoe UI', sans-serif;
  }
  #win-logo { margin-bottom:8px; }
  #win-spinner { position:relative; width:48px; height:48px; }
  #spin-arc { transform-origin:center; animation:spin 1.4s linear infinite; }
  @keyframes spin { to { transform:rotate(360deg); } }

  #win-pct { font-size:clamp(18px,4vw,28px); font-weight:300; letter-spacing:0.02em; }
  #win-title { font-size:clamp(22px,5vw,36px); font-weight:300; letter-spacing:-0.01em; }
  #win-subtitle { font-size:clamp(12px,2vw,16px); opacity:0.7; margin-top:-8px; }

  #win-toolbar {
    position:fixed; bottom:0; left:0; right:0;
    display:flex; gap:8px; padding:10px 16px;
    background:rgba(0,0,0,0.3); border-top:1px solid rgba(255,255,255,0.15);
    transition:opacity 0.3s; z-index:100;
  }
  #win-toolbar.hide { opacity:0; pointer-events:none; }
  .wbtn {
    padding:5px 12px; border-radius:4px;
    border:1px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.15);
    color:white; font-size:12px; cursor:pointer; text-decoration:none;
    transition:background 0.15s;
  }
  .wbtn:hover { background:rgba(255,255,255,0.3); }
</style>

<script>
(function () {
  const pctEl   = document.getElementById('win-pct');
  const toolbar = document.getElementById('win-toolbar');
  const btnFs   = document.getElementById('btn-fs');
  const btnReset = document.getElementById('btn-reset');

  let pct = 0;
  function startProgress() {
    pct = 0;
    const tick = () => {
      if (pct >= 100) { pctEl.textContent = '100%'; return; }
      // Slow at certain milestones (realistic Windows behavior)
      const increment = pct < 30 ? 0.4
        : pct < 60 ? 0.2
        : pct < 80 ? 0.1
        : pct < 95 ? 0.05
        : 0.02;
      pct = Math.min(100, pct + increment + Math.random() * increment);
      pctEl.textContent = Math.floor(pct) + '%';
      setTimeout(tick, 80 + Math.random() * 120);
    };
    tick();
  }
  startProgress();
  btnReset.addEventListener('click', startProgress);

  // Toolbar
  let hideTimer;
  function showBar() {
    toolbar.classList.remove('hide');
    clearTimeout(hideTimer);
    hideTimer = setTimeout(() => toolbar.classList.add('hide'), 3000);
  }
  document.addEventListener('mousemove', showBar, { passive: true });
  document.addEventListener('touchstart', showBar, { passive: true });
  toolbar.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  hideTimer = setTimeout(() => toolbar.classList.add('hide'), 2000);

  btnFs.addEventListener('click', () => {
    if (!document.fullscreenElement) document.documentElement.requestFullscreen();
    else document.exitFullscreen();
  });
})();
</script>
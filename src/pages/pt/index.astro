---
import Layout from '../../layouts/Layout.astro';
import ScreenTool from '../../components/ScreenTool.astro';

const hreflang = [
  { lang: 'en', href: '/' },
  { lang: 'es', href: '/es' },
  { lang: 'pt', href: '/pt' },
  { lang: 'tr', href: '/tr' },
  { lang: 'fr', href: '/fr' },
  { lang: 'de', href: '/de' },
];
---

<Layout
  title="Tela Branca | Tela Branca Online Grátis"
  description="Tela branca completa online — perfeita como ring light, iluminação para selfies e videochamadas. Ajuste brilho e temperatura de cor. Grátis, sem downloads."
  themeColor="#ffffff"
  lang="pt"
  canonical="/pt"
  hreflang={hreflang}
>
  <ScreenTool
    color="#ffffff"
    showTemp={true}
    pageTitle="Tela Branca Online"
  />
</Layout>

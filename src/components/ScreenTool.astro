---
export interface Props {
  color?: string;
  mode?: 'solid' | 'ring';
  showTemp?: boolean;
  pageTitle?: string;
}

const {
  color = '#ffffff',
  mode = 'solid',
  showTemp = false,
  pageTitle = 'Screen Tool',
} = Astro.props;

// Base URL para que los links funcionen tanto en /screen-tools/ como en dominio propio
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<h1 class="sr-only">{pageTitle}</h1>

<div id="app">
  <div id="screen" style={`background-color:${color}`}>
    <canvas id="ring-canvas" aria-hidden="true"></canvas>
  </div>

  <div id="toolbar" role="toolbar" aria-label="Screen controls">
    <div id="tb">

      <!-- Row 1: Presets + saved colors + custom picker -->
      <div id="tb-colors">
        <div id="presets">
          {[
            ['#ffffff', 'White'],
            ['#f9f5ee', 'Warm White'],
            ['#eef3ff', 'Cool White'],
            ['#111111', 'Near Black'],
            ['#000000', 'Black'],
            ['#ff0000', 'Red'],
            ['#ff69b4', 'Pink'],
            ['#ff8c00', 'Orange'],
            ['#ffd700', 'Yellow'],
            ['#00cc44', 'Green'],
            ['#0077ff', 'Blue'],
            ['#9900ff', 'Purple'],
          ].map(([c, name]) => (
            <button
              class={`cp${c === color ? ' act' : ''}`}
              data-c={c}
              title={name}
              style={`--bg:${c}`}
              aria-label={name}
            ></button>
          ))}
        </div>

        <!-- Colores personalizados guardados (localStorage) -->
        <div id="saved-colors"></div>

        <label id="custom-wrap" title="Custom color">
          <svg viewBox="0 0 20 20" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="10" y1="2" x2="10" y2="18"/><line x1="2" y1="10" x2="18" y2="10"/>
          </svg>
          <input type="color" id="custom-color" value={color} />
        </label>
      </div>

      <!-- Row 2: Controles -->
      <div id="tb-controls">

        <!-- Brillo (modifica el color directamente, sin CSS filter) -->
        <label class="ctrl" title="Brightness">
          <svg class="icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <input type="range" id="brightness" min="5" max="100" value="100" />
          <span id="bval">100%</span>
        </label>

        <!-- Temperatura de color (solo visible cuando el color base es blancuzco) -->
        {showTemp && (
          <label class="ctrl" id="temp-ctrl" title="Color Temperature — Cool to Warm">
            <svg class="icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
            </svg>
            <input type="range" id="temperature" min="0" max="100" value="50" />
            <span id="tval">5500K</span>
          </label>
        )}

        <!-- Tamaño del aro (solo visible en ring mode) -->
        <label class="ctrl" id="ring-size-ctrl" style="display:none" title="Ring Size">
          <svg class="icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/>
          </svg>
          <input type="range" id="ring-size" min="15" max="88" value="55" />
        </label>

        <button id="btn-ring" class={`tbtn${mode === 'ring' ? ' act' : ''}`} title="Toggle Ring Light Mode">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/>
          </svg>
          Ring
        </button>

        <button id="btn-fs" class="tbtn" title="Fullscreen — o doble clic en la pantalla">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3H5a2 2 0 0 0-2 2v3M21 8V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3m13-5v3a2 2 0 0 0-2 2h-3"/>
          </svg>
          <span id="fs-label">Fullscreen</span>
        </button>

        <!-- Nav con URLs correctas incluyendo base path -->
        <nav id="qnav" aria-label="Other screens">
          <a href={`${base}/`}              title="White Screen"  class="qn">W</a>
          <a href={`${base}/black-screen`}  title="Black Screen"  class="qn" style="color:#999">B</a>
          <a href={`${base}/red-screen`}    title="Red Screen"    class="qn" style="color:#f77">R</a>
          <a href={`${base}/zoom-lighting`} title="Ring Light"    class="qn" style="color:#adf">◎</a>
        </nav>
      </div>
    </div>
  </div>
</div>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  #app { position: fixed; inset: 0; }

  #screen {
    position: absolute; inset: 0;
    transition: background-color 0.2s ease;
    cursor: default;
  }

  #ring-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  #ring-canvas.show { opacity: 1; }

  /* ── TOOLBAR ─────────────────────────────── */
  #toolbar {
    position: fixed; bottom: 0; left: 0; right: 0;
    z-index: 200;
    padding: 32px 20px 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0) 100%);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  #toolbar.hide {
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
  }

  #tb {
    max-width: 880px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 10px;
  }

  /* Color row */
  #tb-colors { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  #presets   { display: flex; flex-wrap: wrap; gap: 6px; }

  /* Separador visual entre presets y colores guardados */
  #saved-colors {
    display: flex; gap: 6px; flex-wrap: wrap; align-items: center;
  }
  #saved-colors:not(:empty) {
    padding-left: 8px;
    border-left: 1px solid rgba(255,255,255,0.2);
  }

  .cp {
    width: 26px; height: 26px; border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.2);
    background: var(--bg);
    cursor: pointer; flex-shrink: 0;
    transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
  }
  .cp:hover { transform: scale(1.25); border-color: rgba(255,255,255,0.7); }
  .cp.act   { border-color: #fff; box-shadow: 0 0 0 2px rgba(255,255,255,0.35); }

  #custom-wrap {
    width: 26px; height: 26px; border-radius: 50%;
    border: 2px dashed rgba(255,255,255,0.4);
    cursor: pointer; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.6); position: relative; overflow: hidden;
    transition: border-color 0.15s;
  }
  #custom-wrap:hover { border-color: rgba(255,255,255,0.8); }
  #custom-wrap input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }

  /* Controls row */
  #tb-controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

  .ctrl { display: flex; align-items: center; gap: 6px; color: rgba(255,255,255,0.75); cursor: pointer; }
  .icon { flex-shrink: 0; color: rgba(255,255,255,0.55); }

  input[type=range] {
    -webkit-appearance: none; appearance: none;
    width: 88px; height: 4px;
    background: rgba(255,255,255,0.25);
    border-radius: 2px; outline: none; cursor: pointer;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px; border-radius: 50%;
    background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,0.4); cursor: pointer;
  }
  input[type=range]::-moz-range-thumb {
    width: 14px; height: 14px; border-radius: 50%;
    background: #fff; border: none; cursor: pointer;
  }

  #bval, #tval { font-size: 11px; color: rgba(255,255,255,0.45); min-width: 32px; }

  .tbtn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.1);
    color: #fff; font-size: 12px; cursor: pointer; white-space: nowrap;
    transition: background 0.15s, border-color 0.15s;
  }
  .tbtn:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.55); }
  .tbtn.act  { background: rgba(255,255,255,0.22); border-color: #fff; }

  #qnav { display: flex; gap: 5px; margin-left: auto; }
  .qn {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.75);
    text-decoration: none; font-size: 10px; font-weight: 700;
    transition: background 0.15s, border-color 0.15s;
  }
  .qn:hover { background: rgba(255,255,255,0.22); border-color: rgba(255,255,255,0.5); }

  @media (max-width: 560px) {
    input[type=range] { width: 64px; }
    #bval, #tval { display: none; }
    #fs-label { display: none; }
    .tbtn { padding: 5px 8px; }
  }
</style>

<script define:vars={{ initialColor: color, initialMode: mode, hasTemp: showTemp }}>
(function () {
  const screenEl      = document.getElementById('screen');
  const canvas        = document.getElementById('ring-canvas');
  const toolbar       = document.getElementById('toolbar');
  const customColor   = document.getElementById('custom-color');
  const briSlider     = document.getElementById('brightness');
  const bval          = document.getElementById('bval');
  const tempSlider    = document.getElementById('temperature');
  const tval          = document.getElementById('tval');
  const tempCtrl      = document.getElementById('temp-ctrl');
  const ringSizeSlider = document.getElementById('ring-size');
  const ringSizeCtrl  = document.getElementById('ring-size-ctrl');
  const btnRing       = document.getElementById('btn-ring');
  const btnFs         = document.getElementById('btn-fs');
  const fsLabel       = document.getElementById('fs-label');

  // ── ESTADO CENTRAL ────────────────────────────────────────
  // baseColor es el color "puro" elegido por el usuario (sin brillo ni temperatura)
  let baseColor  = initialColor;
  let briValue   = 100;   // 5 – 100
  let tempValue  = 50;    // 0 = frío, 50 = neutro, 100 = cálido
  let isRingMode = initialMode === 'ring';
  let ringSize   = 55;
  let ctx;

  // ── HELPERS DE COLOR ─────────────────────────────────────
  function hexToRgb(hex) {
    const h = hex.replace('#', '');
    return [
      parseInt(h.slice(0, 2), 16),
      parseInt(h.slice(2, 4), 16),
      parseInt(h.slice(4, 6), 16),
    ];
  }

  function clamp(v) { return Math.max(0, Math.min(255, Math.round(v))); }

  // ¿El color es blancuzco? (>200 en los tres canales)
  function isWhitish(hex) {
    try {
      const [r, g, b] = hexToRgb(hex);
      return r > 200 && g > 200 && b > 200;
    } catch { return false; }
  }

  // Calcula el color de temperatura (solo para blancos)
  // t=0 → 6500K (azulado), t=50 → 5500K (neutro blanco), t=100 → 3200K (cálido)
  function tempToRgb(t) {
    if (t <= 50) {
      const p = (50 - t) / 50;
      return [clamp(255 - 18 * p), clamp(255 - 12 * p), 255];
    } else {
      const p = (t - 50) / 50;
      return [255, clamp(255 - 11 * p), clamp(255 - 51 * p)];
    }
  }

  // ── CALCULAR COLOR FINAL (color + temp + brillo) ─────────
  function computeRgb() {
    let [r, g, b] = hexToRgb(baseColor);
    const whitish = isWhitish(baseColor);
    if (whitish && tempValue !== 50) [r, g, b] = tempToRgb(tempValue);
    const f = briValue / 100;
    return [clamp(r * f), clamp(g * f), clamp(b * f)];
  }

  // ── APLICAR ESTADO ────────────────────────────────────────
  function applyState() {
    const whitish = isWhitish(baseColor);
    if (tempCtrl) tempCtrl.style.display = (!isRingMode && whitish) ? 'flex' : 'none';

    screenEl.style.filter = '';
    if (isRingMode) {
      screenEl.style.backgroundColor = '#0a0a0a';
      drawRing();
    } else {
      const [r, g, b] = computeRgb();
      screenEl.style.backgroundColor = `rgb(${r},${g},${b})`;
    }
  }

  // ── COLORES GUARDADOS (localStorage) ─────────────────────
  const STORAGE_KEY = 'sl-custom-colors';
  let savedColors = [];
  try { savedColors = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch {}

  function persistColor(c) {
    savedColors = [c, ...savedColors.filter(x => x !== c)].slice(0, 6);
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(savedColors)); } catch {}
    renderSaved();
  }

  function renderSaved() {
    const el = document.getElementById('saved-colors');
    if (!el) return;
    el.innerHTML = '';
    savedColors.forEach(c => {
      const btn = document.createElement('button');
      btn.className = 'cp';
      btn.style.setProperty('--bg', c);
      btn.dataset.c = c;
      btn.title = c;
      btn.addEventListener('click', () => setColor(c));
      el.appendChild(btn);
    });
    markActive(baseColor);
  }
  renderSaved();

  // ── SELECCIÓN DE COLOR ────────────────────────────────────
  function markActive(c) {
    document.querySelectorAll('.cp').forEach(b => b.classList.toggle('act', b.dataset.c === c));
  }

  function setColor(c) {
    baseColor = c;
    if (customColor) customColor.value = /^#[0-9a-fA-F]{6}$/.test(c) ? c : '#ffffff';
    markActive(c);
    applyState();
  }

  document.querySelectorAll('#presets .cp').forEach(b => {
    b.addEventListener('click', () => setColor(b.dataset.c));
  });

  // Color picker personalizado
  // - input: actualiza color en tiempo real (sin guardar todavía)
  // - change: guarda definitivamente cuando el usuario cierra el picker
  let saveTimer;
  if (customColor) {
    customColor.addEventListener('input', e => {
      setColor(e.target.value);
    });
    customColor.addEventListener('change', e => {
      clearTimeout(saveTimer);
      persistColor(e.target.value);
    });
  }

  // ── BRILLO ────────────────────────────────────────────────
  if (briSlider) {
    briSlider.addEventListener('input', () => {
      briValue = parseInt(briSlider.value, 10);
      if (bval) bval.textContent = briValue + '%';
      applyState();
    });
  }

  // ── TEMPERATURA ───────────────────────────────────────────
  const TEMP_LABELS = ['6500K', '6200K', '5900K', '5500K', '5000K', '4500K', '4000K', '3200K'];
  if (tempSlider) {
    tempSlider.addEventListener('input', () => {
      tempValue = parseInt(tempSlider.value, 10);
      const idx = Math.round(tempValue / 100 * (TEMP_LABELS.length - 1));
      if (tval) tval.textContent = TEMP_LABELS[idx];
      applyState();
    });
  }

  // ── CANVAS ────────────────────────────────────────────────
  function initCanvas() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    ctx = canvas.getContext('2d');
    if (isRingMode) drawRing();
  }
  initCanvas();
  window.addEventListener('resize', initCanvas, { passive: true });

  // ── DIBUJAR ARO ───────────────────────────────────────────
  // Usa el estado actual: baseColor + briValue + tempValue
  function drawRing() {
    if (!ctx) return;
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);

    const [cr, cg, cb] = computeRgb();
    const rgb = `${cr},${cg},${cb}`;

    const cx = W / 2, cy = H / 2;
    const r   = Math.min(W, H) * ringSize / 200;
    const rw  = Math.min(W, H) * 0.052;
    const innerR = Math.max(2, r - rw);
    const outerR = Math.max(innerR + 8, r + rw);

    try {
      // Luz ambiental interior
      const gi = ctx.createRadialGradient(cx, cy, 0, cx, cy, innerR);
      gi.addColorStop(0, `rgba(${rgb},0.18)`);
      gi.addColorStop(1, `rgba(${rgb},0)`);
      ctx.fillStyle = gi;
      ctx.fillRect(0, 0, W, H);
    } catch {}

    try {
      // El aro — más brillante
      const g = ctx.createRadialGradient(cx, cy, innerR, cx, cy, outerR);
      g.addColorStop(0,    `rgba(${rgb},0)`);
      g.addColorStop(0.18, `rgba(${rgb},0.9)`);
      g.addColorStop(0.5,  `rgba(${rgb},1)`);
      g.addColorStop(0.82, `rgba(${rgb},0.9)`);
      g.addColorStop(1,    `rgba(${rgb},0)`);
      ctx.fillStyle = g;
      ctx.beginPath();
      ctx.arc(cx, cy, outerR + 6, 0, Math.PI * 2);
      ctx.arc(cx, cy, Math.max(1, innerR - 6), 0, Math.PI * 2, true);
      ctx.fill();
    } catch {}
  }

  // ── MODO ARO ──────────────────────────────────────────────
  function setRingMode(on) {
    isRingMode = on;
    btnRing.classList.toggle('act', on);
    canvas.classList.toggle('show', on);
    if (ringSizeCtrl) ringSizeCtrl.style.display = on ? 'flex' : 'none';
    applyState();
  }

  if (btnRing) btnRing.addEventListener('click', () => setRingMode(!isRingMode));
  if (ringSizeSlider) {
    ringSizeSlider.addEventListener('input', () => {
      ringSize = parseInt(ringSizeSlider.value, 10);
      drawRing();
    });
  }
  if (isRingMode) setRingMode(true);

  // ── TOOLBAR AUTO-HIDE ─────────────────────────────────────
  let hideTimer;
  function showBar() {
    toolbar.classList.remove('hide');
    clearTimeout(hideTimer);
    hideTimer = setTimeout(() => toolbar.classList.add('hide'), 3500);
  }
  document.addEventListener('mousemove',  showBar, { passive: true });
  document.addEventListener('touchstart', showBar, { passive: true });
  toolbar.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  toolbar.addEventListener('mouseleave', () => {
    hideTimer = setTimeout(() => toolbar.classList.add('hide'), 1500);
  });
  hideTimer = setTimeout(() => toolbar.classList.add('hide'), 2500);

  // ── FULLSCREEN ────────────────────────────────────────────
  function toggleFs() {
    if (!document.fullscreenElement && !document.webkitFullscreenElement) {
      (document.documentElement.requestFullscreen
        || document.documentElement.webkitRequestFullscreen)
          .call(document.documentElement);
    } else {
      (document.exitFullscreen || document.webkitExitFullscreen).call(document);
    }
  }
  if (btnFs) btnFs.addEventListener('click', toggleFs);
  screenEl.addEventListener('dblclick', toggleFs);
  function onFsChange() {
    const isFs = !!(document.fullscreenElement || document.webkitFullscreenElement);
    if (fsLabel) fsLabel.textContent = isFs ? 'Exit' : 'Fullscreen';
  }
  document.addEventListener('fullscreenchange',       onFsChange);
  document.addEventListener('webkitfullscreenchange', onFsChange);

  // ── INIT ─────────────────────────────────────────────────
  applyState();
  markActive(initialColor);
})();
</script>
